{
	"name": "rachis-mcp",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"predeploy": "node scripts/generate-schema-registry.mjs",
		"deploy": "wrangler deploy",
		"predev": "node scripts/generate-schema-registry.mjs",
		"dev": "wrangler dev",
		"format": "oxfmt --write .",
		"lint:fix": "oxlint --fix",
		"start": "wrangler dev",
		"test": "npm run test:build && node --test .tmp-tests/tests/*.test.js",
		"test:build": "rm -rf .tmp-tests && tsc -p tsconfig.test.json && cp -r src/schemas .tmp-tests/src/schemas",
		"cf-typegen": "wrangler types",
		"type-check": "tsc --noEmit"
	},
	"dependencies": {
		"agents": "^0.4.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/node": "^25.2.3",
		"oxfmt": "^0.32.0",
		"oxlint": "^1.47.0",
		"typescript": "5.9.3",
		"wrangler": "^4.65.0"
	}
}
