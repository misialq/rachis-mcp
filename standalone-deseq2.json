{
  "deseq2": {
    "actions": {
      "estimate": {
        "description": "Run DESeq2 differential expression and return both the feature-level statistics artifact and a visualization.",
        "inputs": {
          "table": {
            "type": [
              "FeatureTable[Frequency]"
            ],
            "required": true
          },
          "gene_annotations": {
            "type": [
              "GenomeData[Loci]"
            ],
            "required": false
          }
        },
        "parameters": {
          "condition": {
            "type": "MetadataColumn[Categorical]",
            "required": true
          },
          "reference_id": {
            "type": "Str",
            "required": false
          },
          "reference_level": {
            "type": "Str",
            "required": false
          },
          "min_total_count": {
            "type": "Int % Range(0, None)",
            "required": false
          },
          "fit_type": {
            "type": "Str % Choices('parametric', 'local', 'mean')",
            "required": false
          },
          "size_factor_type": {
            "type": "Str % Choices('ratio', 'poscounts', 'iterate')",
            "required": false
          },
          "alpha": {
            "type": "Float % Range(0.0, 1.0)",
            "required": false
          },
          "cooks_cutoff": {
            "type": "Bool",
            "required": false
          },
          "independent_filtering": {
            "type": "Bool",
            "required": false
          }
        },
        "outputs": {
          "stats": {
            "type": [
              "FeatureData[DESeq2Stats]"
            ]
          },
          "visualization": {
            "type": [
              "Visualization"
            ]
          }
        }
      },
      "estimate_model": {
        "description": "Run DESeq2 using full sample metadata plus a fixed-effects formula and return both the feature-level statistics artifact and a visualization.",
        "inputs": {
          "table": {
            "type": [
              "FeatureTable[Frequency]"
            ],
            "required": true
          },
          "gene_annotations": {
            "type": [
              "GenomeData[Loci]"
            ],
            "required": false
          }
        },
        "parameters": {
          "metadata": {
            "type": "Metadata",
            "required": true
          },
          "fixed_effects_formula": {
            "type": "Str",
            "required": true
          },
          "reference_id": {
            "type": "Str",
            "required": false
          },
          "reference_levels": {
            "type": "List[Str]",
            "required": false
          },
          "effect_specs": {
            "type": "List[Str]",
            "required": false
          },
          "test": {
            "type": "Str % Choices('wald', 'lrt')",
            "required": false
          },
          "reduced_formula": {
            "type": "Str",
            "required": false
          },
          "min_total_count": {
            "type": "Int % Range(0, None)",
            "required": false
          },
          "fit_type": {
            "type": "Str % Choices('parametric', 'local', 'mean')",
            "required": false
          },
          "size_factor_type": {
            "type": "Str % Choices('ratio', 'poscounts', 'iterate')",
            "required": false
          },
          "alpha": {
            "type": "Float % Range(0.0, 1.0)",
            "required": false
          },
          "cooks_cutoff": {
            "type": "Bool",
            "required": false
          },
          "independent_filtering": {
            "type": "Bool",
            "required": false
          }
        },
        "outputs": {
          "stats": {
            "type": [
              "FeatureData[DESeq2Stats]"
            ]
          },
          "visualization": {
            "type": [
              "Visualization"
            ]
          }
        }
      }
    },
    "types": {
      "FeatureData[DESeq2Stats]": "Differential expression statistics generated by DESeq2.",
      "DESeq2Run": "Internal DESeq2 run outputs used to build visualizations without rerunning DESeq2."
    }
  }
}
